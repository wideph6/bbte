# Database (Supabase Postgres connection string)
# Use the "Connection pooling" string for DATABASE_URL (port 6543, ?pgbouncer=true)
# and the direct connection string for DIRECT_URL (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase (for Storage uploads)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# Admin auth (used by seed script — change ADMIN_PASSWORD before first seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
JWT_SECRET="please-change-this-to-a-long-random-string-min-32-chars"

# Optional defaults (also editable from admin panel)
DEFAULT_WHATSAPP_NUMBER="923001234567"
